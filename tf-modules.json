{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboard": true,
  "automerge": false,
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "* 17 1-7 * 1"
  ],
  "reviewers": [
    "team:ops"
  ],
  "labels": [
    "tf-modules"
  ],
  "pre-commit": {
    "enabled": true
  },
  "terraform": {
    "rangeStrategy": "bump"
  },
  "packageRules": [
    {
      "matchDatasources": [
        "terraform-provider",
        "terraform-module"
      ],
      "groupName": "Terraform providers/modules/linters/pre-commit",
      "groupSlug": "tf-all",
      "automerge": false
    },
    {
      "matchPackageNames": [
        "terraform-linters/*",
        "hashicorp/terraform"
      ],
      "groupName": "Terraform providers/modules/linters/pre-commit",
      "groupSlug": "tf-all",
      "automerge": false
    },
    {
      "matchManagers": [
        "pre-commit"
      ],
      "groupName": "Terraform providers/modules/linters/pre-commit",
      "groupSlug": "tf-all",
      "automerge": false
    }
  ]
}
