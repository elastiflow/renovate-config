{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboard": true,
  "automerge": false,
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "* 17 1-7 * 1"
  ],
  "labels": [
    "renovate"
  ],
  "gomod": {
    "rangeStrategy": "bump"
  },
  "cargo": {
    "rangeStrategy": "bump"
  },
  "pre-commit": {
    "enabled": true
  },
  "terraform": {
    "rangeStrategy": "bump"
  },
  "packageRules": [
    // Rust
    {
      "matchManagers": [
        "cargo"
      ],
      "reviewersFromCodeOwners": true,
      "addLabels": [
        "renovate-rust"
      ]
    },
    // GO
    {
      "matchManagers": [
        "gomod"
      ],
      "reviewersFromCodeOwners": true,
      "addLabels": [
        "renovate-go"
      ]
    },
    // GHA
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions",
      "groupSlug": "github-actions",
      "reviewers": [
        "team:ops"
      ],
      "addLabels": [
        "renovate-gha"
      ]
    },
    // pre-commit
    {
      "matchManagers": [
        "pre-commit"
      ],
      "groupName": "Pre commit",
      "groupSlug": "precommit-all",
      "reviewers": [
        "team:ops"
      ],
      "addLabels": [
        "renovate-precommit"
      ]
    },
    // Terraform
    {
      "matchDatasources": [
        "terraform-provider"
      ],
      "groupName": "terraform providers/modules/linters/pre-commit",
      "groupSlug": "tf-all",
      "reviewers": [
        "team:ops"
      ],
      "addLabels": [
        "renovate-terraform"
      ]
    },
    {
      "matchDatasources": [
        "terraform-module"
      ],
      "groupName": "terraform providers/modules/linters/pre-commit",
      "groupSlug": "tf-all",
      "reviewers": [
        "team:ops"
      ],
      "addLabels": [
        "renovate-terraform"
      ]
    },
    {
      "matchPackageNames": [
        "hashicorp/terraform"
      ],
      "enabled": false
    }
  ]
}
